#!/usr/bin/env perl
use warnings;
use strict;
use open qw(locale);

use Getopt::Long;

my $columns;
my $zero;

Getopt::Long::Configure("bundling", "gnu_compat");
Getopt::Long::GetOptions("w|width|columns=i" => \$columns,
                         "z|0|zero|emacs" => \$zero) or die(":-(");

if (!$columns) {                # not specified in CLI
    eval {
        (undef, $columns) = get_screen_size();
    };
    if (!$columns) {
        $columns = 80;
    }
}

my $line_1 = " " x $columns;
my $line_2 = "-" x $columns;
my $start_disp_col_num = 1;
my $end_disp_col_num   = $columns;
my $start_col_idx = 0;
my $end_col_idx = $columns - 1;
if ($zero) {
    $start_disp_col_num -= 1;   # e.g., 0
    $end_disp_col_num -= 1;     # e.g., 171
}
foreach my $col_idx (0 .. $columns - 1) {              # 0..171
    my $disp_col_num = $col_idx + ($zero ? 0 : 1); # 0..171 or 1..172
    if ($disp_col_num % 10 == 0) {
        substr($line_2, $col_idx, 1) = "|";
        my $len = length("$disp_col_num");
        my $end_idx = $col_idx + 1;
        my $start_idx = $end_idx - $len;
        if ($start_idx >= 0 && $end_idx <= $columns) {
            substr($line_1, $start_idx, $len) = "$disp_col_num";
        }
    } elsif ($disp_col_num % 5 == 0) {
        substr($line_2, $col_idx, 1) = ":";
    }
}
print($line_1 . "\n");
print($line_2 . "\n");

my %HAS;
BEGIN {
    eval { require "sys/ioctl.ph"; $HAS{ioctl} = 1;    };
    eval { require Term::Size;     $HAS{TermSize} = 1; };
}
sub get_screen_size {
    if ($HAS{ioctl}) {
        eval {
            die "no TIOCGWINSZ\n" unless defined &TIOCGWINSZ;
            my $tty;
            open($tty, "+</dev/tty") or die "No tty: $!";
            my $winsize;
            unless (ioctl($tty, &TIOCGWINSZ, $winsize='')) {
                die sprintf("$0: ioctl TIOCGWINSZ (%08x: $!)\n",
                            &TIOCGWINSZ);
            }
            my ($row, $col) = unpack('S2', $winsize);
            return ($row, $col);
        };
    }
    if ($HAS{TermSize}) {
        eval {
            my $tty;
            open($tty, "+</dev/tty") or die "No tty: $!";
            my ($columns, $rows) = Term::Size::chars $tty;
            return ($rows, $columns);
        };
    }
    eval {
        my $rows = `tput lines`;
        my $columns = `tput cols`;
        $rows =~ s{\R\z}{};
        $columns =~ s{\R\z}{};
        return ($rows, $columns);
    };
}
